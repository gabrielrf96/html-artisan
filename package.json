{
  "name": "html-artisan",
  "version": "3.0.0",
  "description": "A lightweight JS library for the dynamic, simple and easy-to-read generation of complex HTML structures",
  "main": "src/html-artisan.js",
  "types": "src/html-artisan.d.ts",
  "type": "module",
  "files": [
    "src",
    "!*.test.js"
  ],
  "scripts": {
    "lint": "eslint",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "build": "webpack",
    "typegen": "npx tsc",
    "chver": "npm version --no-git-tag-version",
    "postchver": "node scripts/inject-version.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabrielrf96/html-artisan.git"
  },
  "author": "Gabriel Rodriguez <contact@gabrielrf.dev> (https://www.gabrielrf.dev)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/gabrielrf96/html-artisan/issues"
  },
  "homepage": "https://github.com/gabrielrf96/html-artisan#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "replace-in-file": "^8.4.0",
    "typescript": "^5.9.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1"
  }
}
